# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=darcafeteria
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres
DB_LOGGING=false

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Firebase Admin SDK (push notifications) ─────────────────────────────────
# Required for the admin panel "Notifications" feature and for delivering
# pushes to mobile clients. Get the service-account JSON from
#     Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# Either point at a JSON file…
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/dar-cafeteria-firebase-adminsdk.json
#
# …or inline the three fields directly. The private key MUST keep its
# literal "\n" line breaks — quote the value.
FIREBASE_PROJECT_ID=dar-cafeteria
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
